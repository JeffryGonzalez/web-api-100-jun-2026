      "isDeleted": false,
      "boundElements": null,
      "updated": 1780930403877,
      "link": null,
      "locked": false,
      "text": "- DevOps - the payoff:\n    - Teams should be able to independently deploy new versions of their app whenever they need to.\n        - without coordination of other teams.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- DevOps - the payoff:\n    - Teams should be able to independently deploy new versions of their app whenever they need to.\n        - without coordination of other teams.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
