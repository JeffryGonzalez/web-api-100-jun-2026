      "text": "Legacy: .NET Framework - \n    - Only runs on windows\n    - definitely not your first choice for anything.\n    - Try to do it with \"Core\"\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Legacy: .NET Framework - \n    - Only runs on windows\n    - definitely not your first choice for anything.\n    - Try to do it with \"Core\"\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
