      "isDeleted": false,
      "boundElements": null,
      "updated": 1781106362139,
      "link": null,
      "locked": false,
      "text": "\"Scoped\" - this means \"one per request, and lives as long as that request. Not shared across concurrent requests.\"\n    - since they are associated with a particular request, they are associated with a \"user' in a way too.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Scoped\" - this means \"one per request, and lives as long as that request. Not shared across concurrent requests.\"\n    - since they are associated with a particular request, they are associated with a \"user' in a way too.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
